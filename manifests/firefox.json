{
  "manifest_version": 2,
  "name": "BOOTH New Product Discord Notifier",
  "description": "指定したBOOTHタグの新着商品を拡張機能内一覧とDiscordに通知します。",
  "version": "0.3.0",
  "permissions": [
    "alarms",
    "storage",
    "https://booth.pm/*",
    "https://discord.com/api/webhooks/*"
  ],
  "background": {
    "scripts": [
      "src/product-parser.js",
      "src/background.js"
    ],
    "persistent": false
  },
  "icons": {
    "128": "icons/notification-128.png"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_title": "BOOTH新着通知",
    "default_popup": "src/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "booth-new-product-discord-notifier@moyu1254.local",
      "strict_min_version": "109.0"
    }
  }
}
