{
  "manifest_version": 3,
  "name": "BOOTH New Product Discord Notifier",
  "description": "指定したBOOTHタグの新着商品を拡張機能内一覧とDiscordに通知します。",
  "version": "0.3.0",
  "permissions": [
    "alarms",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "https://booth.pm/*",
    "https://discord.com/api/webhooks/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "128": "icons/notification-128.png"
  },
  "options_page": "src/options.html",
  "action": {
    "default_title": "BOOTH新着通知",
    "default_popup": "src/popup.html"
  }
}
